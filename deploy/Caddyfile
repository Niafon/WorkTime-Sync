worksyncdemo.ru, www.worksyncdemo.ru {
    encode gzip

    handle /api/* {
        reverse_proxy api:8000
    }

    handle /docs {
        reverse_proxy api:8000
    }

    handle /openapi.json {
        reverse_proxy api:8000
    }

    handle /health {
        reverse_proxy api:8000
    }

    handle {
        reverse_proxy frontend:3000
    }
}
